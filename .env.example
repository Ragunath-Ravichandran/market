# Market Intelligence Suite - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============ API KEYS ============
# Get your Groq API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get your Google API key from: https://console.cloud.google.com
GOOGLE_API_KEY=your_google_api_key_here

# Get your Tavily API key from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ============ BACKEND CONFIG ============
# Backend URL for local development
BACKEND_URL=http://localhost:8000

# Debug mode (set to True for development, False for production)
DEBUG=True

# Environment: development, staging, production
ENVIRONMENT=development

# ============ CORS CONFIG ============
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============ DATABASE ============
# ChromaDB settings (if needed)
CHROMA_DB_PATH=./chroma_data

# ============ LOGGING ============
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============ DEPLOYMENT ============
# Set to your deployed backend URL when going to production
DEPLOYED_BACKEND_URL=https://your-api.render.com
DEPLOYED_FRONTEND_URL=https://yourusername.github.io/market
